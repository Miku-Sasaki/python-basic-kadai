     "text": [
      "--- forループ ---\n",
      "水\n",
      "金\n",
      "地\n",
      "火\n",
      "木\n",
      "土\n",
      "天\n",
      "海\n",
      "冥\n",
      "\n",
      "--- whileループ ---\n",
      "水\n",
      "金\n",
      "地\n",
      "火\n",
      "木\n",
      "土\n",
      "天\n",
      "海\n",
      "冥\n"
     ]
    }
   ],
   "source": [
    "array = [\"水\", \"金\", \"地\", \"火\", \"木\", \"土\", \"天\", \"海\", \"冥\"]\n",
    "\n",
    "# forループを利用した場合\n",
    "print(\"--- forループ ---\")\n",
    "for planet in array:\n",
    "    print(planet)\n",
    "\n",
    "# whileループを利用した場合\n",
    "print(\"\\n--- whileループ ---\")\n",
    "i = 0\n",
    "while i < len(array):\n",
    "    print(array[i])\n",
    "    i += 1"
   ]
